{:paths ["src"]
 :deps {org.clojure/clojure {:mvn/version "1.12.1"}
        org.clojure/core.async {:mvn/version "1.7.701"}

        ;; yggdrasil — HLC-coordinated multi-store versioning (snapshot/branch/merge).
        org.replikativ/yggdrasil {:mvn/version "0.2.23"}

        ;; Storage backends the adapters wrap. Published coords (no forks) so the
        ;; jar resolves standalone; a host may override datalevin with a fork.
        org.replikativ/datahike {:mvn/version "0.8.1719"}
        datalevin/datalevin {:mvn/version "0.10.18"}
        org.replikativ/proximum {:mvn/version "0.1.24"}
        org.replikativ/konserve {:mvn/version "0.9.352"}

        ;; hive-dsl — Result/rescue DSL (workspace late-bind seam).
        io.github.hive-agi/hive-dsl {:mvn/version "0.5.2"}

        com.taoensso/timbre {:mvn/version "6.8.0"}}

 :aliases
 {:test {:extra-paths ["test"]
         :extra-deps  {io.github.cognitect-labs/test-runner
                       {:git/tag "v0.5.1" :git/sha "dfb30dd"}}
         :main-opts ["-m" "cognitect.test-runner"]
         :exec-fn cognitect.test-runner.api/test}

  ;; Clojars publishing. version = the repo's VERSION file (see build.clj).
  :build
  {:deps {io.github.clojure/tools.build {:mvn/version "0.10.9"}
          slipset/deps-deploy {:mvn/version "0.2.2"}}
   :ns-default build}}}
